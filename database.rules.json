{
  "rules": {
    ".read": false,
    ".write": false,

    "users": {
      "$uid": {
        ".read": "auth != null",
        ".write": "$uid === auth.uid",
        "nickname": { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 16" },
        "friendCode": { ".validate": "newData.isString() && newData.val().length <= 16" },
        "coins": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1000000000" },
        "scarecrowLv": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100000" },
        "scytheLv": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100000" },
        "plotSize": { ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 200" },
        "equippedDecor": { ".validate": "newData.isString() && newData.val().length <= 24" },
        "equippedMsgSkin": { ".validate": "newData.isString() && newData.val().length <= 24" },
        "equippedTheme": { ".validate": "newData.isString() && newData.val().length <= 24" },
        "equippedTitle": { ".validate": "newData.isString() && newData.val().length <= 24" },
        "equippedCursor": { ".validate": "newData.isString() && newData.val().length <= 24" },
        "cosmetics": {
          "$cid": { ".validate": "newData.isBoolean() || newData.isString()" }
        },
        "dex": {
          "$tier": {
            "h": { ".validate": "newData.isNumber() && newData.val() >= 0" },
            "s": {
              "$victim": { ".validate": "newData.isNumber() && newData.val() >= 0" }
            },
            "$other": { ".validate": false }
          }
        },
        "dexClaimed": { ".validate": "newData.isBoolean()" },
        "$other": { ".validate": false }
      }
    },

    "friendCodes": {
      ".read": "auth != null",
      "$code": {
        ".write": "auth != null && !data.exists() && newData.val() === auth.uid",
        ".validate": "newData.isString()"
      }
    },

    "presence": {
      "$uid": {
        ".read": "auth != null",
        ".write": "$uid === auth.uid"
      }
    },

    "friends": {
      "$uid": {
        ".read": "$uid === auth.uid",
        "$friendUid": {
          ".write": "$uid === auth.uid || ($friendUid === auth.uid && newData.val() === true)",
          ".validate": "newData.isBoolean()"
        }
      }
    },

    "plots": {
      "$uid": {
        ".read": "auth != null",
        ".write": "$uid === auth.uid || root.child('raids').child($uid).child('raiders').child(auth.uid).exists()",
        "crops": {
          "$slot": {
            "tier": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 99" },
            "plantedAt": { ".validate": "newData.isNumber()" },
            "$other": { ".validate": false }
          }
        },
        "weeds": {
          "$slot": {
            "by": { ".validate": "newData.isString()" },
            "at": { ".validate": "newData.isNumber()" },
            "nick": { ".validate": "newData.isString() && newData.val().length <= 16" },
            "skin": { ".validate": "newData.isString() && newData.val().length <= 32" },
            "$other": { ".validate": false }
          }
        }
      }
    },

    "raids": {
      "$targetUid": {
        ".read": "auth != null",
        "ownerCursor": {
          ".write": "auth.uid === $targetUid",
          "x": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1" },
          "y": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1" },
          "$other": { ".validate": false }
        },
        "raiders": {
          "$raiderUid": {
            ".write": "auth != null && auth.uid !== $targetUid && ($raiderUid === auth.uid && (data.exists() || ((root.child('presence').child($targetUid).child('lastSeen').val() > now - 100000 || root.child('presence').child($targetUid).child('connections').exists()) && root.child('friends').child(auth.uid).child($targetUid).val() === true))) || auth.uid === $targetUid",
            "startedAt": { ".validate": "newData.isNumber()" },
            "durationMs": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 600000" },
            "evicted": { ".validate": "newData.isBoolean()" },
            "evictHits": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1000" },
            "cursor": {
              "x": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1" },
              "y": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1" },
              "$other": { ".validate": false }
            },
            "$other": { ".validate": false }
          }
        },
        "$other": { ".validate": false }
      }
    },

    "cooldowns": {
      "$targetUid": {
        "$raiderUid": {
          ".read": "auth != null",
          ".write": "$raiderUid === auth.uid || auth.uid === $targetUid",
          ".validate": "newData.isNumber() && newData.val() <= now"
        }
      }
    },

    "messages": {
      "$uid": {
        ".read": "$uid === auth.uid",
        ".write": "$uid === auth.uid || root.child('raids').child($uid).child('raiders').child(auth.uid).exists()",
        "$msgId": {
          "from": { ".validate": "newData.isString()" },
          "text": { ".validate": "newData.isString() && newData.val().length <= 120" },
          "at": { ".validate": "newData.isNumber()" },
          "skin": { ".validate": "newData.isString() && newData.val().length <= 24" },
          "$other": { ".validate": false }
        }
      }
    },

    "chat": {
      ".read": "auth != null",
      "$msgId": {
        ".write": "auth != null && ((!data.exists() && newData.child('uid').val() === auth.uid) || (!newData.exists() && data.child('uid').val() === auth.uid))",
        "uid": { ".validate": "newData.isString() && newData.val() === auth.uid" },
        "nick": { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 16" },
        "text": { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 200" },
        "at": { ".validate": "newData.isNumber()" },
        "$other": { ".validate": false }
      }
    },

    "raidlog": {
      ".read": "auth != null",
      "$id": {
        ".write": "auth != null && !data.exists() && newData.child('raider').val() === auth.uid",
        "raider": { ".validate": "newData.isString() && newData.val() === auth.uid" },
        "raiderNick": { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 16" },
        "victim": { ".validate": "newData.isString()" },
        "victimNick": { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 16" },
        "coins": { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "count": { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "at": { ".validate": "newData.isNumber()" },
        "$other": { ".validate": false }
      }
    },

    "stats": {
      "$uid": {
        ".read": "auth != null",
        ".write": "$uid === auth.uid",
        "out": {
          "raids": { ".validate": "newData.isNumber() && newData.val() >= 0" },
          "crops": { ".validate": "newData.isNumber() && newData.val() >= 0" },
          "coins": { ".validate": "newData.isNumber() && newData.val() >= 0" },
          "$other": { ".validate": false }
        },
        "vs": {
          "$victim": {
            "raids": { ".validate": "newData.isNumber() && newData.val() >= 0" },
            "crops": { ".validate": "newData.isNumber() && newData.val() >= 0" },
            "coins": { ".validate": "newData.isNumber() && newData.val() >= 0" },
            "$other": { ".validate": false }
          }
        },
        "day": {
          "date": { ".validate": "newData.isString() && newData.val().length <= 10" },
          "out": {
            "raids": { ".validate": "newData.isNumber() && newData.val() >= 0" },
            "crops": { ".validate": "newData.isNumber() && newData.val() >= 0" },
            "coins": { ".validate": "newData.isNumber() && newData.val() >= 0" },
            "$other": { ".validate": false }
          },
          "vs": {
            "$victim": {
              "raids": { ".validate": "newData.isNumber() && newData.val() >= 0" },
              "crops": { ".validate": "newData.isNumber() && newData.val() >= 0" },
              "coins": { ".validate": "newData.isNumber() && newData.val() >= 0" },
              "$other": { ".validate": false }
            }
          },
          "$other": { ".validate": false }
        },
        "$other": { ".validate": false }
      }
    }
  }
}
