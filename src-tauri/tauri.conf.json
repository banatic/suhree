{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "suhree",
  "version": "0.3.5",
  "identifier": "com.suhree.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "strip",
        "title": "suhree",
        "width": 1280,
        "height": 480,
        "x": 0,
        "y": 0,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "focus": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ4REFGNzA1ODFEQjdFQ0YKUldUUGZ0dUJCZmZhMkpGc0M0VzdJMmEyZU54RFlJSnpOR3VwS29HenBrQ3NQLzNRdzJVY3NhdncK",
      "endpoints": [
        "https://raw.githubusercontent.com/banatic/suhree/refs/heads/main/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
